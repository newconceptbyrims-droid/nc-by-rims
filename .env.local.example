# Copier ce fichier en .env.local et renseigner les valeurs réelles.

# Clé API Resend (https://resend.com) pour l'envoi des emails du formulaire de contact.
RESEND_API_KEY=

# Adresse email du salon qui doit recevoir les demandes de contact.
CONTACT_TO_EMAIL=

# Adresse d'expédition (doit appartenir à un domaine vérifié dans Resend).
# Laisser vide pour utiliser l'adresse de test onboarding@resend.dev en attendant.
CONTACT_FROM_EMAIL=

# Chaîne de connexion Postgres (créée via Vercel → Storage → Create Database),
# nécessaire pour la prise de rendez-vous et les emails automatiques.
DATABASE_URL=

# Secret partagé pour sécuriser l'appel de /api/cron (Vercel l'envoie automatiquement
# en en-tête Authorization si cette variable est définie côté projet Vercel).
CRON_SECRET=
